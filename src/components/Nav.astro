---
import { withBase } from '../utils/url';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/familie/', label: 'Familie' },
  { href: '/kennis/', label: 'Kennis' },
  { href: '/duiven/', label: 'Duiven', inProgress: true },
  { href: '/bloedlijnen/', label: 'Bloedlijnen', inProgress: true },
  { href: '/veiling/', label: 'Veiling', inProgress: true },
  { href: '/generaties-van-morgen/', label: 'Toekomst', inProgress: true },
  { href: '/verhalen/', label: 'Verhalen' },
  { href: '/media/', label: 'Media' },
  { href: '/contact/', label: 'Contact' },
  { href: '/zoeken/', label: 'Zoeken' },
];

const base = import.meta.env.BASE_URL;
const rel = Astro.url.pathname.startsWith(base) ? Astro.url.pathname.slice(base.length - 1) : Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return rel === '/';
  return rel.startsWith(href);
}
---

<header class="site-header">
  <div class="container header-bar">
    <a class="brand" href={withBase('/')}>
      <span class="brand-mark">BD</span>
      <span class="brand-name">Berends Duiven</span>
    </a>
    <button class="nav-toggle" aria-expanded="false" aria-controls="primary-nav" id="nav-toggle">
      <span class="visually-hidden">Menu</span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <div class="display-controls" role="group" aria-label="Weergave-instellingen">
      <button id="fontsize-toggle" title="Tekstgrootte aanpassen" aria-label="Tekstgrootte aanpassen">
        <span aria-hidden="true">A</span><span class="fontsize-plus" aria-hidden="true">+</span>
      </button>
      <button id="theme-toggle" title="Licht of donker" aria-label="Wissel tussen licht en donker">
        <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" />
          <path d="M12 3a9 9 0 0 1 0 18Z" fill="currentColor" />
        </svg>
      </button>
    </div>
    <nav id="primary-nav" class="primary-nav" aria-label="Hoofdmenu">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              aria-current={isActive(item.href) ? 'page' : undefined}
              title={item.inProgress ? `${item.label} — in wording` : undefined}
            >
              {item.label}
              {item.inProgress && (
                <span class="in-progress-dot" aria-hidden="true"></span>
              )}
              {item.inProgress && <span class="visually-hidden"> (in wording)</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-chrome-bg);
    border-bottom: 3px solid var(--color-brass);
  }

  .header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
    gap: var(--space-2);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-chrome-text);
  }

  .brand-mark {
    font-family: var(--font-heading);
    font-weight: 700;
    border: 1px solid var(--color-brass);
    color: var(--color-brass-soft);
    width: 2.4rem;
    height: 2.4rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    font-size: 1rem;
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: 1px solid var(--color-brass);
    border-radius: var(--radius);
    padding: 0.6rem;
    cursor: pointer;
  }

  .nav-toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-brass-soft);
  }

  .primary-nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    margin: 0;
    padding: 0;
    justify-content: flex-end;
  }

  .primary-nav a {
    display: inline-block;
    padding: 0.5rem 0.75rem;
    color: var(--color-chrome-text);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: var(--radius);
  }

  .primary-nav a:hover,
  .primary-nav a[aria-current="page"] {
    color: var(--color-chrome-bg);
    background: var(--color-brass-soft);
  }

  .display-controls {
    display: flex;
    gap: 0.4rem;
    order: 2;
  }

  .display-controls button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    background: transparent;
    border: 1px solid rgba(203, 168, 92, 0.55);
    border-radius: var(--radius);
    color: var(--color-chrome-text);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.35rem 0.6rem;
    cursor: pointer;
    line-height: 1;
  }

  .display-controls button:hover {
    border-color: var(--color-brass-soft);
    color: var(--color-brass-soft);
  }

  .fontsize-plus {
    font-size: 0.7em;
    vertical-align: super;
  }

  .in-progress-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    margin-left: 0.4rem;
    margin-bottom: 0.15rem;
    border-radius: 50%;
    background: var(--color-brass-soft);
    vertical-align: middle;
  }

  @media (max-width: 860px) {
    .header-bar {
      flex-wrap: wrap;
    }

    .display-controls {
      margin-left: auto;
    }

    .nav-toggle {
      display: flex;
      order: 2;
    }

    .primary-nav {
      display: none;
      width: 100%;
      order: 3;
    }

    .primary-nav.is-open {
      display: block;
    }

    .primary-nav ul {
      flex-direction: column;
      justify-content: flex-start;
    }

    .primary-nav a {
      padding: 0.85rem 0.5rem;
      border-bottom: 1px solid rgba(233, 223, 205, 0.15);
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('is-open');
  });

  const root = document.documentElement;

  // Tekstgrootte: normaal -> groot -> extra -> normaal
  const sizes = ['normaal', 'groot', 'extra'];
  document.getElementById('fontsize-toggle')?.addEventListener('click', () => {
    const current = root.getAttribute('data-fontsize') ?? 'normaal';
    const next = sizes[(sizes.indexOf(current) + 1) % sizes.length];
    if (next === 'normaal') {
      root.removeAttribute('data-fontsize');
      localStorage.removeItem('bd-fontsize');
    } else {
      root.setAttribute('data-fontsize', next);
      localStorage.setItem('bd-fontsize', next);
    }
  });

  // Thema: automatisch (systeem) -> donker -> licht -> automatisch
  const themes = ['auto', 'donker', 'licht'];
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme') ?? 'auto';
    const next = themes[(themes.indexOf(current) + 1) % themes.length];
    if (next === 'auto') {
      root.removeAttribute('data-theme');
      localStorage.removeItem('bd-theme');
    } else {
      root.setAttribute('data-theme', next);
      localStorage.setItem('bd-theme', next);
    }
  });
</script>
