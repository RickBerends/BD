---
import { withBase } from '../utils/url';
import type { PedigreeNode } from '../utils/duiven';

interface Props {
  node?: PedigreeNode;
  rol: string;
  small?: boolean;
}
const { node, rol, small = false } = Astro.props;
---

<div class:list={['ped-cell', { 'ped-cell--small': small, 'ped-cell--empty': !node }]}>
  <span class="ped-rol">{rol}</span>
  {node ? (
    node.id ? (
      <a href={withBase(`/duiven/${node.id}/`)} class="ped-naam">{node.naam}</a>
    ) : (
      <span class="ped-naam ped-naam--plain">{node.naam}</span>
    )
  ) : (
    <span class="ped-naam ped-naam--unknown">onbekend</span>
  )}
</div>

<style>
  .ped-cell {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-left: 2px solid var(--color-brass);
    border-radius: var(--radius);
    padding: 0.6rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    justify-content: center;
  }

  .ped-cell--small {
    padding: 0.45rem 0.7rem;
  }

  .ped-cell--empty {
    border-left-color: var(--color-border);
    opacity: 0.6;
  }

  .ped-rol {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-brass);
    font-weight: 700;
  }

  .ped-naam {
    font-family: var(--font-heading);
    font-size: 1rem;
  }

  .ped-cell--small .ped-naam {
    font-size: 0.9rem;
  }

  .ped-naam--plain,
  .ped-naam--unknown {
    color: var(--color-ink-soft);
  }

  .ped-naam--unknown {
    font-style: italic;
    font-family: var(--font-body);
    font-size: 0.85rem;
  }
</style>
