---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedEntries from '../../components/RelatedEntries.astro';
import KennisFotos from '../../components/KennisFotos.astro';
import { withBase } from '../../utils/url';

export async function getStaticPaths() {
  const items = await getCollection('kennis');
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const items = (await getCollection('kennis')).sort((a, b) => a.data.order - b.data.order);

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: item.data.title,
  description: item.data.excerpt,
  author: { '@type': 'Person', name: 'Henk Berends' },
  inLanguage: 'nl',
};
---

<BaseLayout title={item.data.title} description={item.data.excerpt} ogType="article" jsonLd={articleLd}>
  <section class="section">
    <div class="container layout">
      <aside class="kennis-nav" aria-label="Kennis-onderwerpen">
        <p class="eyebrow">Kennisbank</p>
        <ul>
          {items.map((i) => (
            <li>
              <a href={withBase(`/kennis/${i.id}/`)} aria-current={i.id === item.id ? 'page' : undefined}>
                {i.data.title}
              </a>
            </li>
          ))}
        </ul>
      </aside>
      <article class="prose">
        <h1>{item.data.title}</h1>
        <KennisFotos ids={item.data.gerelateerdeMedia} />
        <Content />
        <RelatedEntries duivenIds={item.data.gerelateerdeDuiven} bloedlijnId={item.data.gerelateerdeBloedlijn} />
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  @media (max-width: 800px) {
    .layout {
      grid-template-columns: 1fr;
    }
  }

  .kennis-nav ul {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
  }

  .kennis-nav a {
    display: block;
    padding: 0.5rem 0;
    text-decoration: none;
    color: var(--color-ink-soft);
    border-bottom: 1px solid var(--color-border);
  }

  .kennis-nav a[aria-current="page"] {
    color: var(--color-brass);
    font-weight: 700;
  }

  .prose {
    max-width: 70ch;
  }

  .prose :global(h2) {
    margin-top: var(--space-3);
  }

  .prose :global(p) {
    margin-bottom: var(--space-2);
  }

  /* Voerschema-achtige tabellen: van kale browserstijl naar iets dat past
     bij het archief. */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-2) 0 var(--space-3);
    font-size: 0.92rem;
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .prose :global(caption) {
    caption-side: top;
    text-align: left;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-brass);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.6rem 0.85rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(thead th) {
    background: var(--color-wood);
    color: var(--color-bg-raised);
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prose :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(tbody tr:hover) {
    background: var(--color-bg);
  }

  /* Infographics: raw HTML-blokken in de markdown, hier gestyled. Breken op
     brede schermen bewust iets uit de leesbreedte om als beeldelement te
     ademen, blijven op mobiel binnen de kolom. */
  .prose :global(.infographic) {
    margin: var(--space-3) 0;
  }

  @media (min-width: 760px) {
    .prose :global(.infographic) {
      width: calc(100% + 6rem);
      margin-left: -3rem;
    }
  }

  .prose :global(.voerschema-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-2);
  }

  .prose :global(.voerschema-kaart) {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-brass);
    border-radius: var(--radius);
    padding: var(--space-2);
    text-align: center;
  }

  .prose :global(.voerschema-badge) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid var(--color-brass);
    color: var(--color-brass);
    font-family: var(--font-heading);
    font-weight: 700;
    margin-bottom: 0.6rem;
  }

  .prose :global(.voerschema-kaart h3) {
    font-size: 1.05rem;
    margin: 0 0 0.3rem;
  }

  .prose :global(.voerschema-moment) {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .prose :global(.voerschema-basis) {
    font-size: 0.88rem;
    color: var(--color-ink-soft);
    margin: 0;
  }

  /* Afstandslijn: oplopende trainingsafstand als staafjes. */
  .prose :global(.afstandslijn) {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-2) 0;
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .prose :global(.afstand-stap) {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .prose :global(.afstand-staaf) {
    width: 100%;
    max-width: 3.5rem;
    height: calc(var(--afstand, 50) * 0.35px + 1.2rem);
    background: linear-gradient(180deg, var(--color-brass-soft), var(--color-brass));
    border-radius: 3px 3px 0 0;
  }

  .prose :global(.afstand-label) {
    display: block;
    margin-top: 0.5rem;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-wood);
  }

  .prose :global(.afstand-moment) {
    display: block;
    font-size: 0.72rem;
    color: var(--color-ink-soft);
    margin: 0.15rem 0 0.75rem;
    line-height: 1.3;
  }

  /* Seizoensbalk: verduisteren -> licht -> bijlichten als aaneengesloten fasen. */
  .prose :global(.seizoensbalk) {
    display: flex;
    flex-wrap: wrap;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .prose :global(.seizoen-fase) {
    flex: 1;
    min-width: 160px;
    padding: var(--space-2);
    color: var(--color-bg-raised);
  }

  .prose :global(.seizoen-fase--donker) {
    background: var(--color-wood-dark);
  }

  .prose :global(.seizoen-fase--licht) {
    background: var(--color-wood);
  }

  .prose :global(.seizoen-fase--bijlicht) {
    background: var(--color-brass);
    color: var(--color-wood-dark);
  }

  .prose :global(.seizoen-titel) {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
  }

  .prose :global(.seizoen-periode) {
    display: block;
    font-size: 0.82rem;
    opacity: 0.85;
    line-height: 1.4;
  }
</style>
