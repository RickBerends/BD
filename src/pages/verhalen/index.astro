---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../utils/url';

const verhalen = (await getCollection('verhalen')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatter = new Intl.DateTimeFormat('nl-NL', { year: 'numeric', month: 'long' });
---

<BaseLayout
  title="Verhalen"
  description="Wedvluchtverslagen en beschouwingen over de duivensport, geschreven door Henk Berends."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Kennisbank</p>
      <h1>Verhalen</h1>
      <p class="lead">Hieronder de artikelen en verslagen die Henk Berends door de jaren heen schreef.</p>
    </div>
  </section>

  <section class="section section--muted">
    <div class="container story-list">
      {verhalen.map((verhaal) => (
        <a class="card link-card" href={withBase(`/verhalen/${verhaal.id}/`)}>
          <p class="eyebrow">{verhaal.data.category} &middot; {formatter.format(verhaal.data.date)}</p>
          <h2>{verhaal.data.title}</h2>
          <p>{verhaal.data.excerpt}</p>
          <p class="story-author">door {verhaal.data.author}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-size: var(--size-step-1);
    color: var(--color-ink-soft);
    max-width: 65ch;
  }

  .story-list {
    display: grid;
    gap: var(--space-3);
  }

  .link-card {
    text-decoration: none;
    color: inherit;
    transition: border-color 200ms ease, transform 200ms ease;
  }

  .link-card:hover {
    border-color: var(--color-brass);
    transform: translateY(-2px);
  }

  .link-card p {
    color: var(--color-ink-soft);
  }

  .story-author {
    font-style: italic;
    margin: 0;
  }
</style>
