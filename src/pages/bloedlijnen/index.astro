---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import InOpbouw from '../../components/InOpbouw.astro';
import { withBase } from '../../utils/url';
import { duivenInBloedlijn } from '../../utils/duiven';

const bloedlijnen = await getCollection('bloedlijnen');
const metAantal = await Promise.all(
  bloedlijnen.map(async (lijn) => ({ lijn, aantal: (await duivenInBloedlijn(lijn)).length }))
);
---

<BaseLayout
  title="Bloedlijnen"
  description="De stambomen achter de Berends duiven: welke combinaties zijn gemaakt en welke eigenschappen worden doorgegeven."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">De stam</p>
      <h1>Bloedlijnen</h1>
      <p class="lead">
        Een interactieve stamboom is de kennisstructuur waar deze website naartoe groeit &mdash;
        niet alleen namen, maar inzicht: waarom is deze combinatie gemaakt, en welke eigenschappen
        worden doorgegeven?
      </p>

      {bloedlijnen.length === 0 ? (
        <InOpbouw
          title="De stamboom wordt uitgetekend"
          message="Zodra er voldoende gekoppelde duivenprofielen in het archief staan, verschijnen de eerste bloedlijnen hier. Bekijk ondertussen de kennisbank voor de achterliggende fokfilosofie."
        />
      ) : (
        <div class="card-grid">
          {metAantal.map(({ lijn, aantal }) => (
            <a class="card link-card" href={withBase(`/bloedlijnen/${lijn.id}/`)}>
              <h2>{lijn.data.naam}</h2>
              <p>{lijn.data.oorsprong}</p>
              {aantal > 0 && (
                <p class="aantal">{aantal} {aantal === 1 ? 'duif' : 'duiven'} in deze lijn</p>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-size: var(--size-step-1);
    color: var(--color-ink-soft);
    max-width: 65ch;
    margin-bottom: var(--space-3);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-3);
  }

  .link-card {
    text-decoration: none;
    color: inherit;
    transition: border-color 200ms ease, transform 200ms ease;
  }

  .link-card:hover {
    border-color: var(--color-brass);
    transform: translateY(-2px);
  }

  .aantal {
    color: var(--color-brass);
    font-size: 0.85rem;
    font-weight: 600;
    margin: var(--space-1) 0 0;
  }
</style>
