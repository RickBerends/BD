---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InOpbouw from '../../components/InOpbouw.astro';
---

<BaseLayout
  title="Generaties van morgen"
  description="Waar nieuwe kampioenen worden voorgesteld: de geschiedenis van Berends Duiven gaat verder."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">De toekomst</p>
      <h1>Generaties van morgen</h1>
      <p class="lead">
        Hier worden straks de nieuwe kampioenen voorgesteld &mdash; zichtbaar wordt dat de
        geschiedenis van de Berends duiven verdergaat.
      </p>

      <InOpbouw message="Zodra er jonge kweekduiven zijn die de volgende generatie vertegenwoordigen, verschijnen ze hier. Wordt vervolgd." />
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-size: var(--size-step-1);
    color: var(--color-ink-soft);
    max-width: 65ch;
    margin-bottom: var(--space-3);
  }
</style>
