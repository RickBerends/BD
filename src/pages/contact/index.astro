---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Neem contact op met Henk Berends over de Berends duiven.">
  <section class="section">
    <div class="container contact-layout">
      <div>
        <p class="eyebrow">In gesprek</p>
        <h1>Contact</h1>
        <p class="lead">
          Heeft u een vraag of opmerking? Voel u vrij om te mailen &mdash; er wordt zo spoedig
          mogelijk gereageerd.
        </p>

        <form id="contact-form" class="card">
          <p>
            <label for="naam">Naam</label>
            <input id="naam" name="naam" type="text" required maxlength="60" />
          </p>
          <p>
            <label for="email">E-mailadres</label>
            <input id="email" name="email" type="email" required maxlength="80" />
          </p>
          <p>
            <label for="onderwerp">Onderwerp</label>
            <input id="onderwerp" name="onderwerp" type="text" required maxlength="80" />
          </p>
          <p>
            <label for="bericht">Uw bericht</label>
            <textarea id="bericht" name="bericht" rows="6" required></textarea>
          </p>
          <button class="button" type="submit">Verzenden</button>
          <p class="form-note" id="form-note" hidden>
            Uw e-mailprogramma opent zo met dit bericht al ingevuld &mdash; controleer en verstuur
            het vanuit uw eigen mailbox.
          </p>
        </form>

        <p class="fallback">
          Werkt het formulier niet? Dan is Henk rechtstreeks te bereiken via
          <a href="mailto:HenkBerends@ziggo.nl">HenkBerends@ziggo.nl</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const note = document.getElementById('form-note');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const naam = String(data.get('naam') ?? '');
    const email = String(data.get('email') ?? '');
    const onderwerp = String(data.get('onderwerp') ?? '');
    const bericht = String(data.get('bericht') ?? '');

    const body = `Naam: ${naam}\nE-mail: ${email}\n\n${bericht}`;
    const mailto = `mailto:HenkBerends@ziggo.nl?subject=${encodeURIComponent(onderwerp)}&body=${encodeURIComponent(body)}`;

    note?.removeAttribute('hidden');
    window.location.href = mailto;
  });
</script>

<style>
  .lead {
    font-size: var(--size-step-1);
    color: var(--color-ink-soft);
    max-width: 60ch;
    margin-bottom: var(--space-3);
  }

  .contact-layout {
    max-width: 640px;
  }

  form p {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: var(--space-2);
  }

  label {
    font-weight: 600;
    color: var(--color-wood);
  }

  input,
  textarea {
    font: inherit;
    font-size: 1rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    color: var(--color-ink);
  }

  input:focus,
  textarea:focus {
    outline: 2px solid var(--color-brass);
    outline-offset: 1px;
  }

  .form-note {
    margin-top: var(--space-2);
    color: var(--color-ink-soft);
    font-size: 0.9rem;
  }

  .fallback {
    color: var(--color-ink-soft);
    margin-top: var(--space-3);
  }
</style>
