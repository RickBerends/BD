---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../utils/url';

const bundlePath = withBase('/pagefind/');
---

<BaseLayout title="Zoeken" description="Doorzoek het archief van Berends Duiven.">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Archief</p>
      <h1>Zoeken</h1>
      <p class="lead">Doorzoek het familieverhaal, de kennisbank en de verhalen.</p>
      <div class="search-root">
        <pagefind-searchbox
          placeholder="Zoek in het archief…"
          show-sub-results
          autofocus
        >
          <pagefind-config bundle-path={bundlePath}></pagefind-config>
        </pagefind-searchbox>
        <noscript>
          <p>Zoeken vereist JavaScript. Gebruik anders het menu om door het archief te bladeren.</p>
        </noscript>
      </div>
    </div>
  </section>
</BaseLayout>

<link href={`${bundlePath}pagefind-component-ui.css`} rel="stylesheet" />
<script define:vars={{ bundlePath }}>
  import(/* @vite-ignore */ `${bundlePath}pagefind-component-ui.js`).catch(() => {
    const el = document.querySelector('.search-root');
    if (el) {
      el.innerHTML =
        '<p>De zoekindex is nog niet beschikbaar op deze omgeving. Bouw en publiceer de site (npm run build) om te zoeken.</p>';
    }
  });
</script>

<style>
  .lead {
    font-size: var(--size-step-1);
    color: var(--color-ink-soft);
    max-width: 65ch;
    margin-bottom: var(--space-3);
  }

  .search-root {
    max-width: 640px;
  }
</style>
