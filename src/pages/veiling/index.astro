---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InOpbouw from '../../components/InOpbouw.astro';
import { withBase } from '../../utils/url';
---

<BaseLayout
  title="Veiling"
  description="De veiling van Berends Duiven: elke verkoop vertelt een verhaal over een lijn die tientallen jaren zorgvuldig is opgebouwd."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">De Veiling</p>
      <h1>Een unieke kans om eigenaar te worden van levende historie</h1>
      <p class="lead">
        Een veiling is een moment waarop een bijzonder stuk geschiedenis een nieuwe eigenaar krijgt.
        Niet: <em>&ldquo;product X, prijs Y.&rdquo;</em> Maar: deze duif vertegenwoordigt een lijn
        die tientallen jaren zorgvuldig is opgebouwd. De vraag is niet hoeveel een duif kost, maar
        welke toekomst deze duif kan betekenen voor uw hok.
      </p>

      <p class="beschikbaar">
        Uit de prijsvliegende duiven van het afgelopen seizoen &mdash; met resultaten als 7e nationaal
        Sint-Vincent sector 1a, twee kopprijzen op Pau en een 44e nationaal Barcelona &mdash; zijn op
        dit moment jonge duiven beschikbaar. Belangrijkste kweeklijn: Jellema x eigen soort. Interesse?
        Stuur gerust een persoonlijk bericht.
      </p>

      <InOpbouw
        title="De eerste digitale catalogus wordt samengesteld"
        message="Een volledige veilingcatalogus met stamboom, prestaties en biedsysteem per duif is in de maak. Tot die tijd verloopt verkoop via persoonlijk contact — geen 'product X, prijs Y', maar een gesprek over welke lijn bij uw hok past."
      />

      <p><a class="button" href={withBase('/contact/')}>Neem contact op &rarr;</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-size: var(--size-step-1);
    color: var(--color-ink-soft);
    max-width: 65ch;
    margin-bottom: var(--space-3);
  }

  .beschikbaar {
    max-width: 65ch;
    padding: var(--space-2);
    margin-bottom: var(--space-3);
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
</style>
